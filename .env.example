# Database — use either DATABASE_URL or POSTGRES_* (Supabase Session Pooler)
# Session Pooler (port 5432) is recommended for persistent Docker containers.
# Get the exact host from: Supabase Dashboard → Connect → Session pooler
# DATABASE_URL=postgresql://postgres.xxxxxxxxxx:password@aws-0-eu-central-1.pooler.supabase.com:5432/postgres
POSTGRES_HOST=aws-0-eu-central-1.pooler.supabase.com
POSTGRES_PORT=5432
POSTGRES_DB=postgres
POSTGRES_USER=postgres.xxxxxxxxxx
POSTGRES_PASSWORD=your_password

# Supabase Auth (login)
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Server
PORT=80

# Optional: Redis for shared cache (otherwise in-memory)
# REDIS_URL=redis://default:password@host:6379
